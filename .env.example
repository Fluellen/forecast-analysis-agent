AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_MODEL=

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_KEY=

OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL_ID=

TAVILY_API_KEY=

# Langfuse OTLP tracing
# When all three values below are set, the app automatically derives:
# - OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=<LANGFUSE_BASE_URL>/api/public/otel/v1/traces
# - OTEL_EXPORTER_OTLP_TRACES_HEADERS=Authorization=Basic%20<base64(public:secret)>
# - OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional explicit alias for the Langfuse Python SDK. If omitted, the app maps LANGFUSE_BASE_URL to LANGFUSE_HOST automatically.
# LANGFUSE_HOST=https://cloud.langfuse.com

# Optional Langfuse batching controls for faster local troubleshooting
# LANGFUSE_FLUSH_AT=1
# LANGFUSE_FLUSH_INTERVAL=1

# Agent Framework observability controls
# Set ENABLE_SENSITIVE_DATA=true only in dev/test when you want prompts and responses exported.
# ENABLE_INSTRUMENTATION=true
# ENABLE_SENSITIVE_DATA=false
# ENABLE_CONSOLE_EXPORTERS=false
# OTEL_SERVICE_NAME=forecast-analysis-agent

API_PORT=8000
STREAMLIT_PORT=8501
REQUEST_TIMEOUT_SECONDS=120